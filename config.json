{
  "_comment": "WallEye CS2 Server — single configuration entrypoint",
  "match": {
    "required_players": 10,
    "wallhack_duration_seconds": 300,
    "report_phase_duration_seconds": 60,
    "restart_delay_seconds": 5,
    "leaderboard_display_seconds": 10,
    "map": "de_dust2",
    "max_rounds": 30,
    "cheaters_count": 1,
    "cheater_selection": "global",
    "report_scope": "enemy_team"
  },
  "scoring": {
    "points_participation": 10,
    "points_correct_report": 30,
    "points_wrong_report": -20,
    "points_no_cheater_correct": 30,
    "points_kill": 2,
    "points_assist": 1,
    "points_death": -1
  },
  "server": {
    "port": 27015,
    "tv_port": 27020,
    "server_name": "WallEye CS2 Server",
    "insecure": true,
    "autoupdate": false,
    "data_path": "/data",
    "web_leaderboard_port": 8080
  },
  "esp": {
    "provider": "AdminESP",
    "cmd_enable_all": "css_esp_on",
    "cmd_disable_all": "css_esp_off",
    "cmd_enable_player": "css_esp \"{name}\" true",
    "cmd_disable_player": "css_esp \"{name}\" false"
  },
  "ui": {
    "rules_display_seconds": 15,
    "rules_delay_on_connect_seconds": 3,
    "report_menu_open_delay_seconds": 3,
    "wallhack_warning_before_end_seconds": 60,
    "chat_prefix": "[WallEye]"
  },
  "plugins": {
    "metamod_url": "https://github.com/alliedmodders/metamod-source/releases/download/2.0.0.1396/mmsource-2.0.0-git1396-linux.tar.gz",
    "counterstrikesharp_url": "https://github.com/roflmuffin/CounterStrikeSharp/releases/download/v1.0.367/counterstrikesharp-with-runtime-linux-1.0.367.zip",
    "admin_esp_url": "https://github.com/kgarri/bg-koka-cs2-xray-esp/releases/download/v1.0.2/AdminESP.tar.gz"
  },
  "dev": {
    "enabled": true,
    "skip_player_check": true,
    "admin_steam_ids": [
      "76561198107558378",
      "76561199837006592"
    ]
  }
}
